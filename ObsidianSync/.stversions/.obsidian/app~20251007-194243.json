{
  "alwaysUpdateLinks": true,
  "attachmentFolderPath": "files",
  "userIgnoreFilters": [
    "files/",
    "templates/",
    "sources/templates/",
    "periodic/templates/",
    "projects/templates/",
    "types/"
  ],
  "promptDelete": false,
