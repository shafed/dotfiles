(defcfg
process-unmapped-keys yes 
danger-enable-cmd yes
concurrent-tap-hold yes
)

(defvirtualkeys
  to-base (layer-switch base)
)

(defvar
  tot 220  ;; tot=time out tap
  tap-time 200
  hold-time 200
  chord-time 60
  subl-time 200
  tmux-delay 40
)

(deftemplate func (timeouttap timeouthold keytap keyhold)
	(tap-hold $timeouttap $timeouthold 
		(multi $keytap  @.tp) 
		$keyhold
	)
)

;; homerowmodfiltered is a way to force problematic bigrams to become letters not mods
(deftemplate homerowmodfiltered (timeouttap timeouthold keytap keyhold typinglist)
  (tap-hold-release-keys $timeouttap $timeouthold
    (multi $keytap  @.tp)
    $keyhold
    $typinglist ;; Activates $keytap early if a key within $typinglist is pressed before hold activates.
  )
)

(defalias
  ;; call @.tp whenever you want to enter fast typing-layer
  .tp (switch
        ;;(lsft rsft) XX break ;; optional skip typing-layer activation for upper case keys might solves some FJ problems
        ()  (multi
              (layer-switch typing)
              (on-idle 55 tap-vkey to-base) ;; timeouts from 30 to 100 are wide spread
            ) break
      )
  .spc-typing   (multi (layer-switch base) spc) ;; expilcitly leave typing-layer when hitting `space` - this allows experimenting with higher idle timeouts
  aterm (cmd zsh -lc "$HOME/.config/kanata/switchApp.sh kitty kitty")
  azen (cmd zen-browser)
  sshot (cmd hyprshot -m region --clipboard-only)
  sw (cmd hyprctl switchxkblayout kanata next)
)

(defsrc )

(deflayermap (base)
 ;; define home row mods (they act as typing-layer triggers, too )
 f (t! func $tot 160 f lsft)
 j (t! func $tot 160 j rsft)
 d (t! func $tot 160 d lctl)
 k (t! func $tot 160 k rctl)
 s (t! func $tot 160 s lalt)
 l (t! func $tot 160 l ralt)
 a (t! func $tot 160 a lmet)
 ; (t! func $tot 160 ; met)

 ;; define functional keys
 lalt (t! func $tot 160 bspc (layer-while-held apps))
 ralt (t! func $tot 160 ret (layer-while-held apps))
 c (t! func $tap-time $hold-time c C-c)
 v (t! func $tap-time $hold-time v C-v)
 b (t! func $tap-time $hold-time b (macro @aterm 100 C-s $tmux-delay spc)) ;; tmux alternate session
 z (t! func $tap-time $hold-time z (cmd hyprctl dispatch focuscurrentorlast)) ;; focus last window
 x (t! func $tap-time $hold-time x (cmd hyprctl dispatch workspace previous)) ;; focus last workspace

 ;; other
 caps (tap-hold $tap-time $hold-time esc (layer-toggle navi))
 bspc XX
 ret XX
 lsft @sw
 rsft @sw

 ;; define each letter as typing-layer trigger
 q (multi q @.tp) w (multi w @.tp) e (multi e @.tp) r (multi r @.tp) t (multi t @.tp) y (multi y @.tp) u (multi u @.tp) i (multi i @.tp) o (multi o @.tp) p (multi p @.tp) g (multi g @.tp) h (multi h @.tp) n (multi n @.tp) m (multi m @.tp)
)

(deflayermap (typing) 
 a a b b c c d d e e f f g g h h i i j j k k l l m m n n o o p p q q r r s s t t u u v v w w x x y y z z 
 lalt bspc ralt ret
 caps XX ;; key deactivations of caps,... are optional
)

(deflayermap (apps)
  q (cmd hyprctl dispatch killactive)
  w (macro @aterm 300 C-s $tmux-delay C-w)
  ;; e (cmd kitty zsh -i -c "yazi; exec zsh")
  e (macro @aterm 300 C-s $tmux-delay C-y)
  y (cmd zen-browser --new-window https://www.youtube.com/playlist?list=WL)
  o (macro @aterm 300 C-s $tmux-delay C-t)
  a (macro @aterm 300 C-s $tmux-delay C-h)
  s (tap-hold-press $subl-time $subl-time (cmd zen-browser) (layer-toggle browser))
  t (cmd telegram-desktop)
  d (macro @aterm 300 C-s $tmux-delay C-d)
  g (cmd ticktick)
  z (cmd zathura)
  c (macro @aterm 300 C-s $tmux-delay C-c)
  spc (cmd hyprlauncher)
  caps caps
)

(deflayermap (browser)
  e (cmd zen-browser https://mail.google.com/mail/u/0/#inbox)
  d (cmd zen-browser https://lmarena.ai)
  f (cmd zen-browser https://www.perplexity.ai)
  g (cmd zen-browser https://chatgpt.com)
  c (cmd zen-browser https://claude.ai/new)
)

(deflayermap (navi)
  ;; arrow keys
  h lft j down k up l right
  ;; words navigation
  w C-right b C-lft

  ;; mods
 f (t! func $tot 160 f lsft)
 d (t! func $tot 300 d lctl)
 s @sshot
)

(defchordsv2
(a s d f) @sshot $chord-time first-release()
;; (lalt lsft) @sw $chord-time first-release()
(a s) lsft $chord-time first-release()
(; l) rsft $chord-time first-release()
)

(defoverrides
(rctl w) (rctl bspc)
)
