[Unit]
Description=Kanata keyboard remapper
After=graphical-session.target
Wants=graphical-session.target

[Service]
Type=simple
Environment="PATH=/usr/local/bin:/usr/bin:/bin:/usr/local/sbin:/usr/sbin:%h/.local/bin"
Environment="DISPLAY=:0"
ExecStart=/usr/bin/kanata_cmd_allowed --cfg %h/.config/kanata/config.kbd
Restart=on-failure

[Install]
WantedBy=graphical-session.target
